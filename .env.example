# Terragon environment variables.
# Copy to `.env` for local development. Real secrets are provisioned per environment.

# --- Dev flags (G1) ---
# Serve the prototype fixtures instead of live GitHub data. Defaults to true until G5.
USE_FIXTURES=true

# --- Auth.js + GitHub OAuth App (G3) ---
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Encrypts GitHub access tokens at rest (G3).
TERRAGON_ENCRYPTION_KEY=

# --- Database: Neon Postgres via Vercel Marketplace (G3) ---
DATABASE_URL=

# --- Observability (G9) ---
SENTRY_DSN=
